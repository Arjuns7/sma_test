# Hyperliquid API Credentials
# Get these from: https://app.hyperliquid-testnet.xyz → Settings → API Wallets

# Your main wallet address (the one connected to Hyperliquid)
HL_WALLET_ADDRESS=0xYourWalletAddressHere

# Your API wallet private key (NOT your main wallet key!)
HL_PRIVATE_KEY=0xYourApiWalletPrivateKeyHere
